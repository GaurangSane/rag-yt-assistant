{
  "manifest_version": 3,
  "name": "YouTube RAG Assistant",
  "version": "1.0.0",
  "description": "Ask anything about any YouTube video. Get timestamped answers.",

  "permissions": [
    "activeTab",
    "scripting",
    "storage"
  ],

  "host_permissions": [
    "http://localhost:8000/*"
  ],

  "action": {
    "default_popup": "popup.html",
    "default_title": "YouTube RAG Assistant"
  },

  "content_scripts": [
    {
      "matches": ["*://*.youtube.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],

  "icons": {
    "48": "icons/icon48.png"
  }
}