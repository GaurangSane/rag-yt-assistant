{
  "manifest_version": 3,
  "name": "YouTube RAG Assistant",
  "version": "1.1.0",
  "description": "Ask anything about any YouTube video. Get timestamped answers.",

  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "sidePanel"
  ],

  "host_permissions": [
    "http://localhost:8000/*"
  ],

  "action": {
    "default_title": "Open YouTube RAG Assistant"
  },

  "side_panel": {
    "default_path": "popup.html"
  },

  "content_scripts": [
    {
      "matches": ["*://*.youtube.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],

  "background": {
    "service_worker": "background.js"
  },

  "icons": {
    "48": "icons/icon48.png"
  }
}